# FireFeed Telegram Bot Environment Configuration

# Database Configuration
POSTGRES_PASSWORD=your_postgres_password_here

# Environment
ENVIRONMENT=development
DEBUG=false

# Database Configuration (Docker compose automatically provides these)
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=firefeed
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=your_database_password_here
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20
DATABASE_POOL_TIMEOUT=30
DATABASE_POOL_RECYCLE=3600

# Redis Configuration (Docker compose automatically provides these)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=your_redis_password_here
REDIS_SOCKET_TIMEOUT=5
REDIS_CONNECT_TIMEOUT=5
REDIS_KEEPALIVE=true

# Telegram Configuration
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_BOT_NAME=firefeed_bot
TELEGRAM_BOT_USERNAME=firefeed_bot
TELEGRAM_BOT_ID=0
TELEGRAM_BOT_FIRST_NAME=FireFeed
TELEGRAM_BOT_LAST_NAME=Bot
TELEGRAM_BOT_LANGUAGE_CODE=en
TELEGRAM_WEBHOOK_URL=https://your-domain.com/webhook
TELEGRAM_WEBHOOK_PORT=8443
TELEGRAM_WEBHOOK_HOST=0.0.0.0
TELEGRAM_USE_WEBHOOK=false
TELEGRAM_POLLING_TIMEOUT=20
TELEGRAM_ALLOWED_UPDATES=null
TELEGRAM_RATE_LIMIT_REQUESTS=30
TELEGRAM_RATE_LIMIT_WINDOW=60

# FireFeed API Configuration
FIREFEED_API_BASE_URL=http://localhost:8001
FIREFEED_API_TOKEN=your_firefeed_api_token_here
FIREFEED_API_KEY=your_firefeed_api_key_here
FIREFEED_API_TIMEOUT=30
FIREFEED_API_MAX_RETRIES=3
FIREFEED_API_RETRY_DELAY=1.0

# Translation Configuration
TRANSLATION_ENABLED=true
TRANSLATION_DEFAULT_LANGUAGE=en
TRANSLATION_SUPPORTED_LANGUAGES=en,ru,de
TRANSLATION_MAX_TEXT_LENGTH=5000
TRANSLATION_CACHE_TTL=3600

# Cache Configuration
CACHE_ENABLED=true
CACHE_DEFAULT_TTL=300
CACHE_MAX_SIZE=1000
CACHE_CLEANUP_INTERVAL=300

# Security Configuration
JWT_SECRET_KEY=your_jwt_secret_key_here_change_in_production
SECRET_KEY=your_secret_key_here_change_in_production
ALLOWED_HOSTS=null
CORS_ORIGINS=null
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# Monitoring Configuration
MONITORING_ENABLED=true
METRICS_PORT=8080
HEALTH_CHECK_PORT=8081
PROMETHEUS_ENABLED=true
SENTRY_DSN=your_sentry_dsn_here
LOG_LEVEL=INFO

# Development Configuration
DEV_MODE=false
TEST_MODE=false
MOCK_EXTERNAL_SERVICES=false
