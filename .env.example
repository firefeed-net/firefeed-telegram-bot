# FireFeed Telegram Bot Environment Configuration

# API Connection - REQUIRED  
FIREFEED_API_BASE_URL=http://firefeed-api:8000

# Service Token - REQUIRED for health checks/auth (paste generated token)
SERVICE_API_TOKEN=paste_your_telegram-bot_token_here_from_tools_generate_service_token_py

# Redis
REDIS_HOST=redis
REDIS_DB=1
REDIS_PASSWORD=firefeed_redis_pass

# Telegram 
TELEGRAM_TOKEN=your_bot_token_here

# Service ID
SERVICE_ID=telegram-bot

# Logging
LOG_LEVEL=INFO

