# FireFeed Telegram Bot Environment Configuration
# Copy to .env and replace example values with actual ones

# Telegram Bot Token
TELEGRAM_BOT_TOKEN=your_bot_token_here

# JWT Secret Key is managed in root .env

# API Connection - REQUIRED
API_BASE_URL=http://firefeed-api:8000
FIREFEED_API_SERVICE_TOKEN=your_telegram_bot_service_token_here

# Logging
LOG_LEVEL=INFO
