# FireFeed Telegram Bot Environment Configuration
# Copy to .env and replace example values with actual ones

# Telegram Bot Token
TELEGRAM_BOT_TOKEN=your_bot_token_example

# JWT Secret Key - REQUIRED for APIClient (generate with: openssl rand -hex 32)
FIREFEED_JWT_SECRET_KEY=your-secret-key-here

# API Connection - REQUIRED
FIREFEED_API_BASE_URL=http://firefeed-api:8000

# Service Token - REQUIRED for auth (generate with tools/generate_service_token.py)
SERVICE_API_TOKEN=your_generated_token_here

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=1
REDIS_PASSWORD=firefeed_redis_pass_example

# Service ID
SERVICE_ID=telegram-bot

# Logging
LOG_LEVEL=INFO

# Features
RATE_LIMIT_ENABLED=true
CACHE_ENABLED=true
MONITORING_ENABLED=true
